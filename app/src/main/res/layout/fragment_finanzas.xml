<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Selector de Mes para Finanzas -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvMesFinanzas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mes Actual"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <Button
                    android:id="@+id/btnFiltrarMesFinanzas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMBIAR MES"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Ingresos Totales -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INGRESOS DEL PERIODO"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ventas con 'F':" />
                    <TextView android:id="@+id/tvVentasConF" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textColor="#1976D2" />
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ventas sin 'F':" />
                    <TextView android:id="@+id/tvVentasSinF" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textColor="#757575" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL FACTURADO:" android:textStyle="bold" />
                    <TextView android:id="@+id/tvTotalVentas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textStyle="bold" android:textColor="#2E7D32" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Gastos Desglosados -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GASTOS DEL PERIODO"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Insumos / Negocio:" />
                    <TextView android:id="@+id/tvGastoInsumos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textColor="#C62828" />
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gastos Personales:" />
                    <TextView android:id="@+id/tvGastoPersonal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textColor="#757575" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Efectivo:" android:textSize="12sp" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvGastoEfectivo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textSize="12sp" android:textColor="#888888" />
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tarjeta (1 pago):" android:textSize="12sp" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvGastoTarjeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textSize="12sp" android:textColor="#888888" />
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cuotas vigentes este mes:" android:textSize="12sp" android:textColor="#FF5722" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvGastoCuotas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textSize="12sp" android:textColor="#FF5722" android:textStyle="bold" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="8dp" android:layout_marginBottom="12dp" />
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL GASTADO:" android:textStyle="bold" />
                    <TextView android:id="@+id/tvTotalGastos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$0.00" android:textStyle="bold" android:textColor="#C62828" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Balance Final -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:id="@+id/llBalanceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#E8F5E9">
                <TextView
                    android:id="@+id/tvBalanceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GANANCIA NETA DEL PERIODO"
                    android:textSize="12sp"
                    android:textColor="#388E3C" />
                <TextView
                    android:id="@+id/tvBalanceFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- NUEVA Card: Deuda Total Pendiente -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFF3E0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEUDA TOTAL PENDIENTE (A FUTURO)"
                    android:textSize="12sp"
                    android:textColor="#E65100"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvDeudaTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#BF360C" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suma de todas las cuotas que faltan pagar de hoy en adelante."
                    android:textSize="10sp"
                    android:textColor="#E65100"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
