<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_vertical">

    <Button
        android:id="@+id/btnVerGastos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="VER HISTORIAL GASTOS"
        android:backgroundTint="#4CAF50" />

    <Button
        android:id="@+id/btnVerVentas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="VER HISTORIAL VENTAS"
        android:backgroundTint="#2196F3" />

    <Button
        android:id="@+id/btnVerProductos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="VER LISTA PRODUCTOS"
        android:backgroundTint="#FF9800" />

    <Button
        android:id="@+id/btnVerContactos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VER AGENDA CONTACTOS"
        android:backgroundTint="#E91E63" />

</LinearLayout>
